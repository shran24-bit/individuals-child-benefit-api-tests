script:post-response {
  test("Should accept either an empty body or a staging error payload on 401", function() {
    const status = res.getStatus();
    const body = res.getBody();
  
    // First, verify it is genuinely a 401 Unauthorized
    expect(status).to.equal(401);
  
    // Conditional check: local (empty string/null) vs staging (JSON object)
    if (!body || body === "") {
      // Passes locally where the body is completely empty
      expect(body).to.be.empty; 
    } else {
      // Passes on staging where a JSON error payload is injected
      expect(body).to.be.an("object");
      expect(body).to.have.property("code");
      expect(body).to.have.property("message");
     
    }
  });
}
