meta {
  name: N022_AuthValidation_Missing
  type: http
  seq: 2
  tags: [
    DOWNSTREAM
  ]
}

post {
  url: {{api-host}}/{{context-path}}
  body: json
  auth: none
}

headers {
  Accept: application/vnd.hmrc.2.0+json
  ~Authorization: {{authorization}}
}

body:json {
  {
    "firstName": "Laura",
    "secondName": "Taylor",
    "dateOfBirth": "1990-06-27",
    "nino": "AA000008A",
    "bornOnOrAfter": "2025-12-01"
  }
}

assert {
  res.status: eq 401
}
