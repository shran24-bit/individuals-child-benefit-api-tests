meta {
  name: N022_AcceptValidation_Missing
  type: http
  seq: 6
  tags: [
    DOWNSTREAM
  ]
}

post {
  url: {{api-host}}/{{context-path}}
  body: json
  auth: none
}

headers {
  Authorization: {{authorization}}
  ~Accept: application/vnd.hmrc.2.0+json
}

body:json {
  {
    "firstName": "Laura",
    "secondName": "Taylor",
    "dateOfBirth": "1990-06-27",
    "nino": "AA000008A",
    "bornOnOrAfter": "2025-12-01"
  }
}

tests {
  test("Should validate response based on environment behavior (406 vs 404)", function() {
    const status = res.getStatus();
    const body = res.getBody();
    const headers = res.getHeaders();
  
    if (status === 406) {
      expect(body).to.have.property("errors").and.be.an("array");
      expect(body.errors[0]).to.have.property("code", "ACCEPT_HEADER_INVALID");
      expect(body.errors[0]).to.have.property("message", "The accept header is missing or invalid");
  
    //  const expectedCorrelationId = bru.getVar("correlationId");
    //  expect(headers).to.have.property("correlationid", expectedCorrelationId);
  
    } else if (status === 404) {
      
      console.warn("Detected Staging behavior: API returned a 404 instead of 406.");
      expect(status).to.equal(404);
      expect(body).to.be.an("object");
      expect(body).to.have.property("code");
      expect(body).to.have.property("message");
  
    } else {
      fail(`Unexpected status code received: ${status}`);
    }
  });
  
}
