meta {
  name: N006_Citizen_Details_No_ResponseBody
  type: http
  seq: 5
}

post {
  url: {{api-host}}/{{context-path}}
  body: json
  auth: inherit
}

headers {
  Authorization: {{authorization}}
  Accept: application/vnd.hmrc.2.0+json
  ~correlationId: {{correlationId}}
}

body:json {
  {
    "firstName": "Michael",
    "secondName": "Johnson",
    "dateOfBirth": "1990-06-27",
    "nino": "AA000027A",
    "bornOnOrAfter": "2023-05-01"
  }
}

assert {
  res.status: eq 500
  res.body: isEmpty
  ~res.headers.correlationid: eq {{correlationId}}
}

settings {
  encodeUrl: true
  timeout: 0
}
