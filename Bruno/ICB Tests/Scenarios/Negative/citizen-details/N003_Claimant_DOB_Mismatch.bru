meta {
  name: N003_Claimant_DOB_Mismatch
  type: http
  seq: 3
}

post {
  url: {{api-host}}/{{context-path}}
  body: json
  auth: inherit
}

headers {
  Authorization: {{authorization}}
  Accept: application/vnd.hmrc.2.0+json
}

body:json {
  {
    "firstName": "Hannah",
    "secondName": "White",
    "dateOfBirth": "1990-06-28",
    "nino": "AA000012A",
    "bornOnOrAfter": "2023-05-01"
  }
}

assert {
  res.status: eq 404
  res.body: isEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}
