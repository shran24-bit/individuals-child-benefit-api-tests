meta {
  name: N001_Claimant_FirstName_Mismatch
  type: http
  seq: 1
}

post {
  url: {{api-host}}/{{context-path}}
  body: json
  auth: inherit
}

headers {
  Authorization: {{authorization}}
  Accept: application/vnd.hmrc.2.0+json
}

body:json {
  {
    "firstName": "Hanna",
    "secondName": "White",
    "dateOfBirth": "1990-06-27",
    "nino": "AA000012A",
    "bornOnOrAfter": "2024-06-27"
  }
}

assert {
  res.status: eq 404
  res.body: isEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}
