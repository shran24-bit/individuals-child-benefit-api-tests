meta {
  name: N011_1 Child_DOB_AfterProvidedDate+DOD
  type: http
  seq: 2
}

post {
  url: {{api-host}}/{{context-path}}
  body: json
  auth: inherit
}

headers {
  Authorization: {{authorization}}
  Accept: application/vnd.hmrc.2.0+json
}

body:json {
  {
    "firstName": "Andrew",
    "secondName": "Harris",
    "dateOfBirth": "1990-06-27",
    "nino": "AA000013A",
    "bornOnOrAfter": "2023-01-01"
  }
}

assert {
  res.body.eligible: eq true
}

settings {
  encodeUrl: true
  timeout: 0
}
