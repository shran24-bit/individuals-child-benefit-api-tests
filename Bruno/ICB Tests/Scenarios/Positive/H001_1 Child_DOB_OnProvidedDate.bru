meta {
  name: H001_1 Child_DOB_OnProvidedDate
  type: http
  seq: 1
  tags: [
    DOWNSTREAM
  ]
}

post {
  url: {{api-host}}/{{context-path}}
  body: json
  auth: none
}

headers {
  Authorization: {{authorization}}
  Accept: application/vnd.hmrc.2.0+json
}

body:json {
  {
    "firstName": "Laura",
    "secondName": "Taylor",
    "dateOfBirth": "1990-06-27",
    "nino": "AA000008A",
    "bornOnOrAfter": "2025-12-01"
  }
}

assert {
  res.status: eq 200
  res.body.eligible: eq true
}
