meta {
  name: H001_2 Children_DOB_After&BeforeProvidedDate
  type: http
  seq: 2
}

post {
  url: {{api-host}}/{{context-path}}
  body: json
  auth: inherit
}

headers {
  Authorization: {{authorization}}
  Accept: application/vnd.hmrc.2.0+json
}

body:json {
  {
    "firstName": "Robert",
    "secondName": "Anderson",
    "dateOfBirth": "1990-06-27",
    "nino": "AA000007A",
    "bornOnOrAfter": "2025-12-31"
  }
}

assert {
  res.status: eq 200
  res.body.eligible: eq true
}

settings {
  encodeUrl: true
  timeout: 0
}
