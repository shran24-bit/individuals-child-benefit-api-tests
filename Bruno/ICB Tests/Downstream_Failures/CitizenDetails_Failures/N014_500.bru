meta {
  name: N014_500
  type: http
  seq: 2
}

post {
  url: {{api-host}}/{{context-path}}
  body: json
  auth: inherit
}

headers {
  Authorization: {{authorization}}
  Accept: application/vnd.hmrc.2.0+json
}

body:json {
  {
    "firstName": "Michael",
    "secondName": "Johnson",
    "dateOfBirth": "1990-06-27",
    "nino": "AA000026A",
    "bornOnOrAfter": "2023-05-01"
  }
}

assert {
  res.status: eq 500
  res.body: isEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}
